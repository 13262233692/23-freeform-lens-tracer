<RCC>
    <qresource prefix="/shaders">
        <file alias="surface.vert">src/shaders/surface.vert</file>
        <file alias="surface.frag">src/shaders/surface.frag</file>
        <file alias="ray.vert">src/shaders/ray.vert</file>
        <file alias="ray.frag">src/shaders/ray.frag</file>
        <file alias="light.vert">src/shaders/light.vert</file>
        <file alias="light.frag">src/shaders/light.frag</file>
    </qresource>
</RCC>
